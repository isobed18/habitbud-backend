# ============================================================================
# HabitBud Backend - Environment Configuration
# ============================================================================

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/habitbud

# Redis (leave empty for InMemory fallback)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# CORS (comma-separated, for production only)
# CORS_ALLOWED_ORIGINS=https://yourapp.com,https://api.yourapp.com

# Celery (uses Redis by default)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# AI Services (currently shelved)
# IONET_API_KEY=your-ionet-key-here

# Logging
DJANGO_LOG_LEVEL=INFO

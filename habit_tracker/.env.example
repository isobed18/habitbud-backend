# ============================================================================
# HabitBud Backend - Environment Configuration
# ============================================================================

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/habitbud

# Redis (leave empty for InMemory fallback)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# CORS (comma-separated, for production only)
# CORS_ALLOWED_ORIGINS=https://yourapp.com,https://api.yourapp.com

# CSRF trusted origins (production HTTPS admin/forms; comma-separated)
# CSRF_TRUSTED_ORIGINS=https://yourapp.com,https://api.yourapp.com

# Force HTTPS redirect in production (set False if TLS terminates upstream)
# SECURE_SSL_REDIRECT=True

# Expo Push Notifications
# Leave EXPO_ACCESS_TOKEN empty unless you have enabled enhanced push security
# in your Expo account (https://docs.expo.dev/push-notifications/sending-notifications/).
# EXPO_ACCESS_TOKEN=

# Logging
DJANGO_LOG_LEVEL=INFO

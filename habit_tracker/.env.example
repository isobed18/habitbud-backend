# ============================================================================
# HabitBud Backend - Environment Configuration
# ============================================================================

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/habitbud

# Redis for Channels/WebSockets (leave empty for single-process InMemory fallback).
# REDIS_URL takes precedence over REDIS_HOST/REDIS_PORT.
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# API rate limits (DRF throttling)
# THROTTLE_ANON=60/min
# THROTTLE_USER=300/min

# CORS (comma-separated, for production only)
# CORS_ALLOWED_ORIGINS=https://yourapp.com,https://api.yourapp.com

# CSRF trusted origins (production HTTPS admin/forms; comma-separated)
# CSRF_TRUSTED_ORIGINS=https://yourapp.com,https://api.yourapp.com

# Force HTTPS redirect in production (set False if TLS terminates upstream)
# SECURE_SSL_REDIRECT=True

# Expo Push Notifications
# Leave EXPO_ACCESS_TOKEN empty unless you have enabled enhanced push security
# in your Expo account (https://docs.expo.dev/push-notifications/sending-notifications/).
# EXPO_ACCESS_TOKEN=

# In-app purchases (server-side verification)
# Apple: App Store Connect -> App Information -> App-Specific Shared Secret
# APPLE_SHARED_SECRET=
# Google: path to a Play service-account JSON key (see users/payments.py TODO)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# AI check verification (off | ollama | openai-compatible URL provider)
# AI_VERIFY_PROVIDER=off
# AI_VERIFY_URL=http://127.0.0.1:11434
# AI_VERIFY_MODEL=qwen2.5vl:7b
# AI_VERIFY_TIMEOUT=25

# Logging
DJANGO_LOG_LEVEL=INFO
